<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="jp.co.ecsite.dao.PurchasesDetailDAO">

	<insert id="insert"  useGeneratedKeys="true" keyProperty="purchaseDetailId" parameterType="jp.co.ecsite.dto.PurchasesDetailsDTO">
		INSERT INTO public.purchase_details(
			purchase_id, item_id, amount)
		VALUES (#{purchaseId}, #{itemId}, #{amount})
	</insert>
</mapper>